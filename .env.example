# ============================================================
# ForgeCMS environment configuration
# Copy to .env. For Docker, defaults below already work.
# Runtime config (site name, AI keys, theme) is stored in the
# database via the setup wizard - you should NOT need to edit
# this file after the first install.
# ============================================================

# --- Database ---
MYSQL_ROOT_PASSWORD=forge_root_password_change_me
MYSQL_DATABASE=forgecms
MYSQL_USER=forgecms
MYSQL_PASSWORD=forge_password_change_me

# Docker builds DATABASE_URL automatically from MYSQL_* (password is URL-encoded).
# Only set DATABASE_URL manually for non-Docker installs.
# DATABASE_URL=mysql://forgecms:forge_password_change_me@mysql:3306/forgecms

# --- Auth secrets (CHANGE THESE for production) ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
# Used to encrypt sensitive settings (e.g. AI API keys) at rest.
SETTINGS_ENCRYPTION_KEY=replace_with_32_byte_random_hex_key

# --- URLs ---
APP_URL=http://localhost
# Internal URL the web app uses to reach the API (docker network).
API_INTERNAL_URL=http://api:4000
# Public path prefix nginx proxies to the API.
NEXT_PUBLIC_API_URL=/api

# --- Ports (host side) ---
WEB_PORT=3000
API_PORT=4000
HTTP_PORT=80
HTTPS_PORT=443

# --- HTTPS (production VPS with Let's Encrypt) ---
# NGINX_CONF=./docker/nginx/nginx.ssl.conf
# LETSENCRYPT_DIR=/etc/letsencrypt
# APP_URL=https://yourdomain.com

# --- Storage ---
STORAGE_DRIVER=local
UPLOAD_DIR=/data/uploads
BACKUP_DIR=/data/backups
MAX_UPLOAD_MB=25

# --- AI (optional, can also be set in the wizard) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Node ---
NODE_ENV=production
