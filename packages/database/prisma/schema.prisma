// ForgeCMS Prisma schema
// Datasource: MySQL. Files are stored on disk; only metadata lives here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  isActive        Boolean   @default(true)
  twoFactorSecret String?
  twoFactorEnabled Boolean  @default(false)
  // Bumped on password change / forced logout to invalidate refresh tokens.
  tokenVersion    Int       @default(0)
  lastLoginAt     DateTime?
  createdPages    PageVersion[] @relation("PageVersionAuthor")
  posts           Post[]
  aiHistory       AIHistory[]
  auditLogs       AuditLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([roleId])
}

model Page {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  status         String        @default("draft")
  isHomepage     Boolean       @default(false)
  themeId        String?
  theme          Theme?        @relation(fields: [themeId], references: [id])
  seoTitle       String?
  seoDescription String?       @db.Text
  ogImage        String?
  // Snapshot of the currently published document for fast public reads.
  publishedDoc   Json?
  publishedAt    DateTime?
  versions       PageVersion[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([themeId])
}

model PageVersion {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version     Int
  document    Json
  isPublished Boolean  @default(false)
  authorId    String?
  author      User?    @relation("PageVersionAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([pageId, version])
  @@index([pageId])
}

model Post {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?   @db.Text
  document       Json
  status         String    @default("draft")
  coverImage     String?
  seoTitle       String?
  seoDescription String?   @db.Text
  authorId       String?
  author         User?     @relation(fields: [authorId], references: [id])
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([authorId])
}

model Theme {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  category  String?
  preview   String?
  config    Json
  isActive  Boolean  @default(false)
  isBuiltIn Boolean  @default(true)
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Component {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("section")
  blocks    Json
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model MediaFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  path         String
  thumbnailPath String?
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  folder       String   @default("/")
  tags         Json?
  altText      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([folder])
  @@index([mimeType])
}

model Menu {
  id        String     @id @default(cuid())
  name      String
  location  String     @unique
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id       String     @id @default(cuid())
  menuId   String
  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label    String
  url      String
  parentId String?
  parent   MenuItem?  @relation("MenuItemChildren", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuItemChildren")
  order    Int        @default(0)

  @@index([menuId])
  @@index([parentId])
}

model Settings {
  key       String   @id
  value     String   @db.Text
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model AIHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  kind      String
  prompt    String   @db.Text
  response  String   @db.LongText
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([kind])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([entity])
}

model Backup {
  id        String   @id @default(cuid())
  filename  String
  type      String
  size      Int      @default(0)
  status    String   @default("pending")
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}
