{
  "name": "forgecms",
  "version": "0.1.0",
  "private": true,
  "description": "ForgeCMS - AI-powered self-hosted website builder",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @forgecms/database generate",
    "db:migrate": "pnpm --filter @forgecms/database migrate:deploy",
    "db:migrate:dev": "pnpm --filter @forgecms/database migrate:dev",
    "db:seed": "pnpm --filter @forgecms/database seed",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20"
  }
}
